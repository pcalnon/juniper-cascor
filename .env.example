########################################################################################################################################################################################################################
# juniper-cascor Environment Variables
# ------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then encrypt with SOPS:
#   sops -e .env > .env.enc
########################################################################################################################################################################################################################

# API and Access Tokens
HF_TOKEN=
ALPHA_VANTAGE_TOKEN=
SCOUT_TOKEN=
EXA_API_KEY=
KAGGLE_API_TOKEN=
SENTRY_SDK_DSN=

# API Key for LLM Providers
ANTHROPIC_API_KEY=

# PyPI API access tokens
# username: __token__, password: the token value (including pypi- prefix)
JUNIPER_ML_TEST_USERNAME=
JUNIPER_ML_TEST_PYPI=
JUNIPER_ML_USERNAME=
JUNIPER_ML_PYPI=
TWINE_USERNAME=
TWINE_PASSWORD=
TEST_TWINE_USERNAME=
TEST_TWINE_PASSWORD=
