########################################################################################################################################################################################################################
# juniper-cascor Environment Variables
# ------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then encrypt with SOPS:
#   sops -e .env > .env.enc
########################################################################################################################################################################################################################

# === Application Settings (JUNIPER_CASCOR_ prefix) ===
# All settings below are loaded by pydantic-settings with the JUNIPER_CASCOR_ prefix.
# See src/api/settings.py for the full Settings class definition.

# Server
JUNIPER_CASCOR_HOST=127.0.0.1
JUNIPER_CASCOR_PORT=8200
JUNIPER_CASCOR_LOG_LEVEL=INFO
JUNIPER_CASCOR_CORS_ORIGINS=["*"]

# WebSocket
JUNIPER_CASCOR_WS_MAX_CONNECTIONS=50
JUNIPER_CASCOR_WS_HEARTBEAT_INTERVAL_SEC=30

# Security (leave unset to disable authentication)
# JUNIPER_CASCOR_API_KEYS=["your-api-key-here"]
# JUNIPER_CASCOR_RATE_LIMIT_ENABLED=false
# JUNIPER_CASCOR_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Observability
JUNIPER_CASCOR_LOG_FORMAT=text
# JUNIPER_CASCOR_SENTRY_DSN=
# JUNIPER_CASCOR_METRICS_ENABLED=false

# Auto-start training (used by demo profile)
# JUNIPER_CASCOR_AUTO_START=false
# JUNIPER_CASCOR_AUTO_DATASET=spiral
# JUNIPER_CASCOR_AUTO_DATASET_PARAMS={}
# JUNIPER_CASCOR_AUTO_NETWORK={}
# JUNIPER_CASCOR_AUTO_TRAIN_EPOCHS=200

# === External API Tokens ===
HF_TOKEN=
ALPHA_VANTAGE_TOKEN=
SCOUT_TOKEN=
EXA_API_KEY=
KAGGLE_API_TOKEN=
SENTRY_SDK_DSN=

# API Key for LLM Providers
ANTHROPIC_API_KEY=

# === PyPI API access tokens ===
# username: __token__, password: the token value (including pypi- prefix)
JUNIPER_ML_TEST_USERNAME=
JUNIPER_ML_TEST_PYPI=
JUNIPER_ML_USERNAME=
JUNIPER_ML_PYPI=
TWINE_USERNAME=
TWINE_PASSWORD=
TEST_TWINE_USERNAME=
TEST_TWINE_PASSWORD=
